{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PawMap MVP shared enums",
  "type": "object",
  "$defs": {
    "dogPolicyStatus": {
      "type": "string",
      "enum": ["allowed", "restricted", "not_allowed", "unknown"]
    },
    "verificationSourceType": {
      "type": ["string", "null"],
      "enum": [
        "official_website",
        "direct_contact",
        "user_report",
        "onsite_signage",
        "third_party_listing",
        "other",
        null
      ]
    },
    "reportStatus": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    }
  }
}
